
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin()
        // Allow any signed-in user to update ONLY the hasUnreadMessages field (for message notifications)
        || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['hasUnreadMessages']));
      allow delete: if isAdmin();
    }

    match /guidanceRequests/{guidanceRequestId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(request.resource.data.studentId);
      allow update: if isSignedIn() && (
        // Author can update their own post content
        isOwner(resource.data.studentId)
        ||
        // Others can only update the likes field, and only if they're not the author
        (request.auth.uid != resource.data.studentId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']))
      );
      allow delete: if isOwner(resource.data.studentId) || isAdmin();

      match /replies/{replyId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isOwner(resource.data.authorId) || isAdmin();
      }
    }

    match /opportunities/{opportunityId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(request.resource.data.alumniId);
      allow update, delete: if isOwner(resource.data.alumniId) || isAdmin();
    }

    // Allow collectionGroup queries for messages where user is sender, receiver, or in unreadBy
    match /{path=**}/messages/{messageId} {
      allow read: if isSignedIn() && 
        (resource.data.senderId == request.auth.uid || 
         resource.data.receiverId == request.auth.uid ||
         ('unreadBy' in resource.data && request.auth.uid in resource.data.unreadBy));
    }

    match /conversations/{conversationId}/messages/{messageId} {
      allow read: if isSignedIn() && (conversationId.split('_')[0] == request.auth.uid || conversationId.split('_')[1] == request.auth.uid);
      allow create: if isOwner(request.resource.data.senderId);
      allow delete: if isOwner(resource.data.senderId);
      // Allow updating only the unreadBy field (for marking messages as read)
      allow update: if isSignedIn() 
        && (conversationId.split('_')[0] == request.auth.uid || conversationId.split('_')[1] == request.auth.uid)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['unreadBy']);
    }
    // Global stats counters (read-only for all signed-in users, writable to increment)
    match /stats/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}
